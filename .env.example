# Anthropic — get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Google OAuth — from console.cloud.google.com
GOOGLE_CLIENT_ID=....apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
# Dev:  http://localhost:3001/api/auth/callback
# Prod: https://YOUR-APP.up.railway.app/api/auth/callback
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/callback

# Twilio WhatsApp — from console.twilio.com
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...

# Your Railway public URL (set automatically by Railway, or set manually for webhooks)
PUBLIC_URL=https://YOUR-APP.up.railway.app

# For Railway: path to the SQLite file on the attached volume
DB_PATH=/data/events.db

# Where the React frontend lives (used after OAuth redirect)
# Dev: http://localhost:5173 — Prod: leave empty (same origin)
FRONTEND_URL=http://localhost:5173

# Any random 32+ char string — used to sign JWTs
JWT_SECRET=change-me-to-something-random-and-long

# Set to "production" on Railway
NODE_ENV=development
PORT=3001
